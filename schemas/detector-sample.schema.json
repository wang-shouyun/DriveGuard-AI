{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DriveGuard-AI Detector Sample",
  "type": "object",
  "required": [
    "timestamp",
    "mode",
    "level",
    "fatigue_score",
    "reason",
    "frame_path",
    "ear",
    "mar",
    "perclos",
    "blink_rate",
    "yawn_count",
    "eye_closed_seconds",
    "pitch",
    "yaw",
    "roll",
    "quality_score",
    "calibration_progress",
    "risk_factors",
    "detector_backend",
    "feature_origin",
    "measurement_valid",
    "perception_state",
    "processing_fps",
    "latency_ms"
  ],
  "properties": {
    "protocol_version": {"type": "integer", "const": 1},
    "message_type": {"type": "string", "const": "sample"},
    "timestamp": {"type": "string"},
    "mode": {"type": "string", "enum": ["simulation", "camera", "video"]},
    "level": {"type": "string", "enum": ["normal", "light", "moderate", "severe", "invalid"]},
    "fatigue_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "reason": {"type": "string"},
    "frame_path": {"type": "string"},
    "ear": {"type": "number"},
    "mar": {"type": "number"},
    "perclos": {"type": "number", "minimum": 0, "maximum": 1},
    "blink_rate": {"type": "number"},
    "yawn_count": {"type": "integer", "minimum": 0},
    "eye_closed_seconds": {"type": "number", "minimum": 0},
    "pitch": {"type": "number"},
    "yaw": {"type": "number"},
    "roll": {"type": "number"},
    "quality_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "calibration_progress": {"type": "integer", "minimum": 0, "maximum": 100},
    "adaptive_ear_threshold": {"type": "number"},
    "adaptive_mar_threshold": {"type": "number"},
    "risk_factors": {"type": "array"},
    "detector_backend": {"type": "string"},
    "feature_origin": {"type": "string"},
    "measurement_valid": {"type": "boolean"},
    "perception_state": {"type": "string"},
    "processing_fps": {"type": "number", "minimum": 0},
    "latency_ms": {"type": "number", "minimum": 0}
  }
}
